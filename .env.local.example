# ─── Local mode (default) ───
# Leave Supabase vars empty to use data/leads.json on this computer.
# No login required.

# Optional local agent API key (leave empty = open access)
# AGENT_API_KEY=your-local-dev-key


# ─── Cloud mode (cross-device) ───
# Set all of these to enable Supabase sync + login.
# See DEPLOY.md for step-by-step setup.

# NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Your user UUID from Supabase → Authentication → Users (after sign-up)
# TRACKER_OWNER_USER_ID=your-user-uuid

# Required in production for job-search agent API
# AGENT_API_KEY=your-long-random-secret